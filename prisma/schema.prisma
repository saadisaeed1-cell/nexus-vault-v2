generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String               @id @default(cuid())
  name              String?
  email             String?              @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  isAdmin           Boolean              @default(false)
  pendingAlert      String?
  resetToken        String?              @unique
  resetExpires      DateTime?
  nxcBalance        Float                @default(0)
  currency          String               @default("USD")
  createdAt         DateTime             @default(now())
  accounts          Account[]
  bundleOpenings    BundleOpening[]
  gameNotifications GameNotification[]
  nxcTransactions   NxcTransaction[]
  orders            Order[]
  refundRequests    RefundRequest[]
  sessions          Session[]
  subscription      Subscription?
  tickets           SupportTicket[]
  collectionItems   UserCollectionItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  paypalOrderId        String?
  paymentProvider      String   @default("stripe")
  status               String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  imageUrl        String?
  region          String             @default("GLOBAL")
  category        String             @default("GAME")
  publisher       String             @default("Unknown")
  publisherId     String?
  isActive        Boolean            @default(true)
  isFeatured      Boolean            @default(false)
  isAndroidOnly   Boolean            @default(false)
  visibilityScope String             @default("ALL")
  pub             Publisher?         @relation(fields: [publisherId], references: [id])
  notifications   GameNotification[]
  products        Product[]

  @@index([isActive])
}

model GameNotification {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  notified  Boolean  @default(false)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([notified])
}

model Product {
  id               String      @id @default(cuid())
  gameId           String
  name             String
  description      String?
  amount           String
  costPrice        Float       @default(0)
  retailPrice      Float
  memberPrice      Float
  officialPrice    Float?
  imageUrl         String?
  eurRetailPrice   Float?
  eurMemberPrice   Float?
  eurOfficialPrice Float?
  currency         String      @default("USD")
  region           String      @default("GLOBAL")
  badge            String?
  groupName        String?
  visibilityScope  String      @default("ALL")
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  orderItems       OrderItem[]
  game             Game        @relation(fields: [gameId], references: [id])
}

model Settings {
  id                 String   @id @default("singleton")
  memberLimit        Int      @default(200)
  memberOverride     Int?
  membershipPrice    Float    @default(49.99)
  membershipPriceEur Float    @default(49.99)
  forceWaitlist      Boolean  @default(false)
  telegramBotToken   String?
  telegramChatId     String?
  telegramEnabled    Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model Publisher {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#22c55e")
  initials  String   @default("NV")
  logoUrl   String?
  createdAt DateTime @default(now())
  games     Game[]
}

model SupportTicket {
  id               String    @id @default(cuid())
  contact          String
  message          String
  status           String    @default("OPEN")
  source           String    @default("support")
  hasUnread        Boolean   @default(false)
  adminUnread      Boolean   @default(false)
  adminUnreadCount Int       @default(0)
  sessionKey       String?
  rating           Int?
  ratingComment    String?
  needsRating      Boolean   @default(false)
  userId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  messages         Message[]
  order            Order?
  user             User?     @relation(fields: [userId], references: [id])
}

model Message {
  id        String        @id @default(cuid())
  ticketId  String
  sender    String
  content   String?
  imageUrl  String?
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Order {
  id                     String         @id @default(cuid())
  userId                 String?
  status                 String         @default("PENDING_PAYMENT")
  pricePaid              Float
  subtotal               Float?
  discountAmount         Float          @default(0)
  serviceFee             Float          @default(0)
  isNexusMember          Boolean        @default(false)
  stripeSessionId        String?
  paypalOrderId          String?
  paymentProvider        String         @default("stripe")
  guestEmail             String?
  transactionRef         String?
  currency               String         @default("USD")
  receiptRequested       Boolean        @default(false)
  isArchived             Boolean        @default(false)
  completedAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  
  productId              String?
  isMemberPrice          Boolean        @default(false)
  gameLogin              String?
  gamePassword           String?
  loginMethod            String?
  activationEmail        String?
  notes                  String?
  credentialsSubmittedAt DateTime?
  
  items                  OrderItem[]
  history                OrderHistory[]
  ticket                 SupportTicket? @relation(fields: [ticketId], references: [id])
  ticketId               String?        @unique
  user                   User?          @relation(fields: [userId], references: [id])
  rating                 OrderRating?
  refundRequest          RefundRequest?
  
  @@index([userId])
  @@index([status])
  @@index([isArchived])
  @@index([isNexusMember])
}

model OrderRating {
  id         String   @id @default(cuid())
  orderId    String?  @unique
  userId     String?
  stars      Int
  comment    String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  productId       String
  gameTitle       String
  itemName        String
  playerId        String?
  serverId        String?
  quantity        Int       @default(1)
  priceAtPurchase Float
  currency        String    @default("USD")
  status          String    @default("PENDING")
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([status])
}

model OrderHistory {
  id          String   @id @default(cuid())
  orderId     String
  action      String
  description String
  adminId     String?
  adminName   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model WaitlistEntry {
  id            String    @id @default(cuid())
  email         String    @unique
  status        String    @default("WAITING")
  isInvited     Boolean   @default(false)
  reservedUntil DateTime?
  inviteToken   String?   @unique
  invitedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model NxcTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  nxcAmount   Float
  usdValue    Float
  orderId     String?
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefundRequest {
  id           String    @id @default(cuid())
  orderId      String    @unique
  userId       String
  email        String
  reason       String
  status       String    @default("PENDING")
  refundMethod String?
  processedAt  DateTime?
  processedBy  String?
  adminNote    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("ADMIN")
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CollectionItem {
  id            String               @id @default(cuid())
  name          String
  description   String?
  rarity        String
  type          String
  totalSupply   Int                  @default(0)
  mintedCount   Int                  @default(0)
  imageUrl      String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  bundleItems   BundleItem[]
  wonInOpenings BundleOpening[]
  userItems     UserCollectionItem[]

  @@index([rarity])
  @@index([type])
  @@index([isActive])
}

model UserCollectionItem {
  id       String         @id @default(cuid())
  userId   String
  itemId   String
  quantity Int            @default(1)
  mintedAt DateTime       @default(now())
  source   String?
  item     CollectionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
}

model Bundle {
  id          String          @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  price       Float
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       BundleItem[]
  openings    BundleOpening[]

  @@index([isActive])
}

model BundleItem {
  id               String         @id @default(cuid())
  bundleId         String
  collectionItemId String
  probability      Float
  createdAt        DateTime       @default(now())
  bundle           Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  collectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)

  @@index([bundleId])
  @@index([collectionItemId])
}

model BundleOpening {
  id        String         @id @default(cuid())
  bundleId  String
  userId    String
  wonItemId String
  pricePaid Float
  openedAt  DateTime       @default(now())
  bundle    Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wonItem   CollectionItem @relation(fields: [wonItemId], references: [id], onDelete: Cascade)

  @@index([bundleId])
  @@index([userId])
  @@index([openedAt])
}
